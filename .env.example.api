# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true

# Flask + FastAPI on ONE port (default when running `python main.py`): uvicorn on FLASK_PORT; FastAPI is under EQ_SQL_API_MOUNT_PATH.
# FLASK_HOST=0.0.0.0
# FLASK_PORT=8880
# EQ_SQL_API_MOUNT_PATH=/eq-sql-api
# Optional override for Flask→FastAPI calls (normally inferred): API_BASE_URL=http://127.0.0.1:8880/eq-sql-api
#
# Legacy two-process mode (Flask + separate uvicorn): set EQ_LEGACY_SPLIT_SERVERS=true and e.g. API_PORT=8000, API_BASE_URL=http://localhost:8000
# EQ_LEGACY_SPLIT_SERVERS=true

# API Authentication Keys
# IMPORTANT: Change these in production to secure values!
API_ACCESS_KEY=your-secure-access-key
API_SECRET_KEY=your-secure-secret-key

# CORS Configuration
CORS_ORIGINS=http://localhost,http://localhost:3000,http://localhost:5000,http://localhost:8880

# OpenAI Configuration (from existing setup)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-3.5-turbo

# Database Configuration (from existing setup)
DB_PATH=C:\eStream\SQLAccounting\ACC-TEST.FDB
DB_HOST=
DB_USER=sysdba
DB_PASSWORD=masterkey

# Base API URL for PHP backend (no trailing slash). Must reach getCompanyNames.php etc., e.g. http://localhost:8080
BASE_API_URL=http://localhost:8080
# Optional: connect,read seconds for HTTP clients (defaults in parentheses)
# PHP_API_REQUEST_TIMEOUT=3,10
# FASTAPI_REQUEST_TIMEOUT=3,15
# INTERNAL_HTTP_REQUEST_TIMEOUT=2,12

# --- SQL Accounting HTTP API (SigV4) — used by eQuotation /salesquotation etc. ---
# SQL_API_ACCESS_KEY=
# SQL_API_SECRET_KEY=
# SQL_API_HOST=api.sql.my
# SQL_API_REGION=ap-southeast-1
# SQL_API_SERVICE=execute-api
# SQL_API_CUSTOMER_CREATE_PATH=/customer
# SQL_API_SALES_QUOTATION_PATH=/salesquotation
# SQL_API_STOCK_ITEM_LIST_PATH=/stockitem
# Optional: longer read timeout for large stock lists (defaults to SQL_API_TIMEOUT_SECONDS).
# SQL_API_STOCK_ITEM_TIMEOUT_SECONDS=60
# Stock code applied when a quotation line has no item code (custom text / unresolved catalog). Must exist in ST_ITEM.
# SQL_API_QUOTATION_FALLBACK_ITEM_CODE=MISC
# Line defaults for /salesquotation (SQL Accounting often requires UOM, location, project; IRBM for MY e-invoice).
# SQL_API_QUOTATION_DEFAULT_UOM=UNIT
# SQL_API_QUOTATION_DEFAULT_LOCATION=----
# SQL_API_QUOTATION_DEFAULT_PROJECT=----
# SQL_API_QUOTATION_DEFAULT_IRBM=022
# Resolve ST_ITEM.CODE from local DB_PATH when the browser did not send a code (same company file as API recommended).
# SQL_API_QUOTATION_LOCAL_ITEMCODE_LOOKUP=true
# Optional fuzzy ST_ITEM match by DESCRIPTION substring (use with care). Default off.
# SQL_API_QUOTATION_LOCAL_ITEMCODE_CONTAINING=false
# Log upstream JSON/text on failed salesquotation POST (server console only).
# SQL_API_QUOTATION_LOG_UPSTREAM=false
