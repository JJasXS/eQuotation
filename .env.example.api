# API Configuration
#
# --- Minimal .env (production-style) ---
# Put non-secrets in ``appsettings.json`` at the repo root. Your ``.env`` can be only:
#   TENANT_CODE=TNT10004
# Optional: ``TenantBootstrap__AwsApiKey`` if API Gateway requires ``x-api-key``.
# SQL + OpenAI credentials then load from AWS Secrets Manager (Dynamo ``sqlApiCredentialsSecretRef``,
# ``openaiApiKeySecretRef``). For local dev without AWS, set ``TENANT_BOOTSTRAP_SKIP_SECRETS=1`` and copy
# ``appsettings.Local.json.example`` to ``appsettings.Local.json`` with keys filled in.
#
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true

# Flask + FastAPI on ONE port (default when running `python main.py`): uvicorn on FLASK_PORT; FastAPI is under EQ_SQL_API_MOUNT_PATH.
# FLASK_HOST=0.0.0.0
# FLASK_PORT=8880
# EQ_SQL_API_MOUNT_PATH=/eq-sql-api
# Optional override for Flask→FastAPI calls (normally inferred): API_BASE_URL=http://127.0.0.1:8880/eq-sql-api
#
# Legacy two-process mode (Flask + separate uvicorn): set EQ_LEGACY_SPLIT_SERVERS=true and e.g. API_PORT=8000, API_BASE_URL=http://localhost:8000
# EQ_LEGACY_SPLIT_SERVERS=true

# API Authentication Keys
# IMPORTANT: Change these in production to secure values!
API_ACCESS_KEY=your-secure-access-key
API_SECRET_KEY=your-secure-secret-key

# CORS Configuration
CORS_ORIGINS=http://localhost,http://localhost:3000,http://localhost:5000,http://localhost:8880

# OpenAI Configuration (from existing setup)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-3.5-turbo

# Database Configuration (from existing setup)
DB_PATH=C:\eStream\SQLAccounting\ACC-TEST.FDB
DB_HOST=
DB_USER=sysdba
DB_PASSWORD=masterkey

# Base API URL for PHP backend (no trailing slash). Must reach getCompanyNames.php etc., e.g. http://localhost:8080
BASE_API_URL=http://localhost:8080
# Optional: connect,read seconds for HTTP clients (defaults in parentheses)
# PHP_API_REQUEST_TIMEOUT=3,10
# FASTAPI_REQUEST_TIMEOUT=3,15
# INTERNAL_HTTP_REQUEST_TIMEOUT=2,12

# --- SQL Accounting HTTP API (SigV4) — used by eQuotation /salesquotation etc. ---
# SQL_API_ACCESS_KEY=
# SQL_API_SECRET_KEY=
# SQL_API_HOST=api.sql.my
# SQL_API_REGION=ap-southeast-1
# SQL_API_SERVICE=execute-api
# SQL_API_CUSTOMER_CREATE_PATH=/customer
# SQL_API_SALES_QUOTATION_PATH=/salesquotation
# SQL_API_STOCK_ITEM_LIST_PATH=/stockitem
# Guest sign-in dropdowns: list GET paths (defaults /area and /currency). Set to empty to use Firebird only.
# SQL_API_AREA_PATH=/area
# SQL_API_CURRENCY_PATH=/currency

# --- Tenant bootstrap (Dynamo via same HTTP API as ProAccScanner) ---
# When TENANT_CODE is set, eQuotation fetches the tenant and sets DB_HOST, DB_PATH, and (if present) sqlApi -> SQL_API_*.
# Dynamo item should include at least ``database`` (dbHost, dbPath) like ProAccScanner; add optional ``sqlApi`` for quotation POST:
#   sqlApi: accessKey, secretKey, host, region, service, customerCreatePath, salesQuotationPath, stockItemListPath, useTls
# Optional env (defaults match ProAccScanner appsettings invoke URL):
# TENANT_CODE=TNT10004
# TENANT_BOOTSTRAP_API_URL=https://....execute-api....amazonaws.com/default/proacc-tenant-config-api
# TENANT_BOOTSTRAP_API_KEY=...   (x-api-key if your API Gateway requires it)
# TENANT_BOOTSTRAP_SKIP=1       (disable fetch; use .env only)
# Optional on ``database``: dbUser, dbPassword (otherwise DB_USER / DB_PASSWORD from .env or sysdba/masterkey).
# OPENAI_API_KEY may be omitted when TENANT_CODE is set and Dynamo ``openai`` + Secrets Manager supply the key (see below).
#
# Dynamo ``openai`` map (optional):
#   openaiApiKeySecretRef  (or openaiCredentialsSecretRef) → Secrets Manager SecretString JSON with BOTH:
#     {"openaiApiKey":"sk-...","openaiModel":"gpt-4o-mini"}
#   When the secret is JSON, ``openaiModel`` on Dynamo is ignored (single source of truth = secret).
#   Plaintext secret (sk-... only): pair with Dynamo ``openaiModel`` / ``model`` for OPENAI_MODEL.
#   Optional: openaiRegion (defaults with AWS_REGION / TENANT_BOOTSTRAP_SECRETS_REGION / ap-southeast-1).
# Dynamo ``sqlApi`` may use sqlApiCredentialsSecretRef → JSON { "accessKey":"...", "secretKey":"..." }.
# TENANT_BOOTSTRAP_SECRETS_REGION=ap-southeast-1
# TENANT_BOOTSTRAP_SKIP_SECRETS=1   (no GetSecretValue; use .env keys only)
# Optional: read timeout for area/currency list GETs (defaults to SQL_API_TIMEOUT_SECONDS).
# SQL_API_REFERENCE_LIST_TIMEOUT_SECONDS=15
# Optional: page size when following pagination (default 200, max 500).
# SQL_API_REFERENCE_PAGE_LIMIT=200
# Optional: longer read timeout for large stock lists (defaults to SQL_API_TIMEOUT_SECONDS).
# SQL_API_STOCK_ITEM_TIMEOUT_SECONDS=60
# Stock code applied when a quotation line has no item code (custom text / unresolved catalog). Must exist in ST_ITEM.
# SQL_API_QUOTATION_FALLBACK_ITEM_CODE=MISC
# Line defaults for /salesquotation (SQL Accounting often requires UOM, location, project; IRBM for MY e-invoice).
# SQL_API_QUOTATION_DEFAULT_UOM=UNIT
# SQL_API_QUOTATION_DEFAULT_LOCATION=----
# SQL_API_QUOTATION_DEFAULT_PROJECT=----
# SQL_API_QUOTATION_DEFAULT_IRBM=022
# Resolve ST_ITEM.CODE from local DB_PATH when the browser did not send a code (same company file as API recommended).
# SQL_API_QUOTATION_LOCAL_ITEMCODE_LOOKUP=true
# Optional fuzzy ST_ITEM match by DESCRIPTION substring (use with care). Default off.
# SQL_API_QUOTATION_LOCAL_ITEMCODE_CONTAINING=false
# Log upstream JSON/text on failed salesquotation POST (server console only).
# SQL_API_QUOTATION_LOG_UPSTREAM=false
